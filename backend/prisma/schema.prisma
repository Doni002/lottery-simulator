// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                String    @id @default(cuid())
  drawSpeed         Int       @default(750) // milliseconds
  randomSeedEnabled Boolean   @default(false)
  customNumbers     Json?     // Array of 5 custom winning numbers: number[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tickets           Ticket[]
  draw              Draw?
}

model Ticket {
  id        Int       @id @default(autoincrement())
  sessionId String
  numbers   Json      // Array of selected numbers: number[]
  isWinner  Boolean   @default(false)
  createdAt DateTime  @default(now())
  session   Session   @relation(fields: [sessionId], references: [id])
}

model Draw {
  id             Int      @id @default(autoincrement())
  sessionId      String   @unique
  winningNumbers Json     // Array of winning numbers: number[]
  drawDate       DateTime
  createdAt      DateTime @default(now())
  session        Session  @relation(fields: [sessionId], references: [id])
}